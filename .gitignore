# Source Moodle backup — too large to track (5.5GB)
*.mbz

# Local Claude / agent state
.claude/

# Build inputs and outputs that aren't part of the deliverable
_work/
_templates/
build.py
filtered.log
categorization.txt
tests/
mbz/

# Deliverable file types — override the user's global .gitignore which
# excludes *.pdf and *.xml. The course content lives in PDFs and we want
# to commit them as part of the static site. (_work/ is still excluded
# above, so the source-backup PDFs inside it stay ignored.)
!*.pdf
!*.xml
